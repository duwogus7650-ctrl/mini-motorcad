[Scripting]
ScriptLines=75
Script[0]="'' example Script"
Script[1]="' this is the main function called when the run script button is pressed"
Script[2]="' the function is passed the current title of the motor project"
Script[3]="Function MainFunction(Title)"
Script[4]="  dim mcad"
Script[5]="  set mcad = createobject(""motorcad.appautomation"")"
Script[6]="  call mcad.showmessage(""example of script for ""+ Title)"
Script[7]=""
Script[8]=" ' speed up the set by setting to avoid immediate update of input"
Script[9]="  call mcad.AvoidImmediateUpdate(true)"
Script[10]=""
Script[11]="  ' set all messages to display in a separate window"
Script[12]="  ' Warning: this will disable crucial popups e.g. prompts to save files, overwrite data etc"
Script[13]="  ' Please ensure this is the behaviour you want"
Script[14]="  call mcad.SetVariable(""MessageDisplayState"",2)"
Script[15]=""
Script[16]="  ' set the radial cross section display"
Script[17]="  'call mcad.DisplayScreen(""Radial"")"
Script[18]=""
Script[19]="  ' example of call to a separate function"
Script[20]="  mySecondFunction(mcad)"
Script[21]=""
Script[22]="  ' set the scripting display"
Script[23]="  call mcad.DisplayScreen(""Scripting"")"
Script[24]=""
Script[25]="  ' restore the message dialogs"
Script[26]="  call mcad.SetVariable(""MessageDisplayState"", 0)"
Script[27]=""
Script[28]="End Function"
Script[29]=""
Script[30]="' this is an example of a separate function that takes mcad as a parameter"
Script[31]="Function mySecondFunction(mcad)"
Script[32]="  for toothWidth = 1 to 3 step .5"
Script[33]="    call mcad.showmessage(""Tooth width = "" + CStr(toothWidth))"
Script[34]="    call mcad.SetVariable(""Tooth_Width"", toothWidth)"
Script[35]="    call mcad.DoSteadyStateAnalysis"
Script[36]="    call mcad.GetVariable(""T_[WINDING_AVERAGE]"", temperature)"
Script[37]="    call mcad.showmessage(""Winding temperature = "" + CStr(temperature))"
Script[38]=""
Script[39]="    ' to be able to stop a script from the stop button need this code in the innermost loop"
Script[40]="    ' this asks Motor-CAD if the stop button has been pressed"
Script[41]="    if mcad.IsStopRequested then exit function end if"
Script[42]=""
Script[43]=""
Script[44]="  Next"
Script[45]=""
Script[46]=""
Script[47]="'  myExcelCall"
Script[48]=""
Script[49]="End Function"
Script[50]=""
Script[51]="' this function is called the first time when scripting is run during the analysis"
Script[52]="' this allows parameters to be initialised"
Script[53]="Function Initialisation(Title)"
Script[54]=""
Script[55]="End Function"
Script[56]=""
Script[57]="' this function is called when scripting is run during the analysis after the duty cycle has completed"
Script[58]="' this allows any calculations to be made at the end of the transient"
Script[59]="Function Finalisation(Title)"
Script[60]=""
Script[61]="End Function"
Script[62]=""
Script[63]=""
Script[64]=""
Script[65]=""
Script[66]="' this is an example of putting values into excel"
Script[67]="'Function myExcelCall"
Script[68]="'  dim excel"
Script[69]="'  set excel = createObject(""excel.application"")"
Script[70]="'  excel.visible = TRUE"
Script[71]="'  excel.workbooks.add"
Script[72]=""
Script[73]="'  excel.cells(1,1).value = ""temperature"""
Script[74]="'End Function"

[Python_Scripting]
ScriptLines_Python=117
Python_Script[0]=""
Python_Script[1]="# ---------- DEMO SCRIPT ----------"
Python_Script[2]=""
Python_Script[3]="# Need to import pymotorcad to access Motor-CAD"
Python_Script[4]="import ansys.motorcad.core as pymotorcad"
Python_Script[5]=""
Python_Script[6]="# Connect to Motor-CAD"
Python_Script[7]="mcApp = pymotorcad.MotorCAD()"
Python_Script[8]=""
Python_Script[9]=""
Python_Script[10]="# This function is called when ""Run"" is pressed"
Python_Script[11]="def main():"
Python_Script[12]="    # We can use main to test functions before running a calculation"
Python_Script[13]="    # e.g. running thermal steady initial function"
Python_Script[14]="    user_func = thermal_steady()"
Python_Script[15]="    user_func.initial()"
Python_Script[16]=""
Python_Script[17]="    # Or we can use main to run calculations"
Python_Script[18]="    demo_func()"
Python_Script[19]=""
Python_Script[20]=""
Python_Script[21]="# demo function which sets tooth_width and runs thermal calculations"
Python_Script[22]="def demo_func():"
Python_Script[23]="    array_tooth_widths = [1, 1.5, 2.0]"
Python_Script[24]=""
Python_Script[25]="    # set all messages to display in a separate window"
Python_Script[26]="    # Warning: this will disable crucial popups e.g. prompts to save files, overwrite data etc"
Python_Script[27]="    # Please ensure this is the behaviour you want"
Python_Script[28]="    mcApp.set_variable(""MessageDisplayState"", 2)"
Python_Script[29]=""
Python_Script[30]="    for toothWidth in array_tooth_widths:"
Python_Script[31]="        mcApp.show_message(""Tooth width = "" + str(toothWidth))"
Python_Script[32]="        mcApp.set_variable(""Tooth_Width"", toothWidth)"
Python_Script[33]="        mcApp.do_steady_state_analysis()"
Python_Script[34]="        temperature = mcApp.get_variable(""T_[WINDING_AVERAGE]"", )"
Python_Script[35]="        mcApp.show_message(""Winding temperature = "" + str(temperature))"
Python_Script[36]=""
Python_Script[37]="        # restore the message dialogs"
Python_Script[38]="    mcApp.set_variable(""MessageDisplayState"", 0)"
Python_Script[39]=""
Python_Script[40]=""
Python_Script[41]="# ---------- FUNCTIONS RUN DURING CALCULATIONS ----------"
Python_Script[42]="# These will only run if using ""Run During Analysis"" selected"
Python_Script[43]="# (Scripting -> Settings -> Run During Analysis)"
Python_Script[44]=""
Python_Script[45]="# If ""Run During Analysis"" is selected then this script will be imported."
Python_Script[46]="# This means that anything other than setting up the MotorCAD object should"
Python_Script[47]="# be moved to a function/class to avoid unexpected behaviour"
Python_Script[48]=""
Python_Script[49]="# This class contains functions for steady-state thermal calculations"
Python_Script[50]="class thermal_steady():"
Python_Script[51]="    def initial(self):"
Python_Script[52]="        # Called before calculation"
Python_Script[53]="        self.step = 0"
Python_Script[54]="        print('Thermal Steady State - Initial')"
Python_Script[55]=""
Python_Script[56]="    def main(self):"
Python_Script[57]="        # Called before each time step in calculation"
Python_Script[58]="        self.step = self.step + 1"
Python_Script[59]="        print('Step: ' + str(self.step) + '. Thermal Steady State - Main')"
Python_Script[60]=""
Python_Script[61]="    def final(self):"
Python_Script[62]="        # Called after calculation"
Python_Script[63]="        print('Thermal Steady State - Final')"
Python_Script[64]=""
Python_Script[65]="    # This class contains functions for trasient thermal calculations"
Python_Script[66]=""
Python_Script[67]=""
Python_Script[68]="class thermal_transient():"
Python_Script[69]="    def initial(self):"
Python_Script[70]="        # Called before calculation"
Python_Script[71]="        self.step = 0"
Python_Script[72]="        print('Thermal Transient - Initial')"
Python_Script[73]=""
Python_Script[74]="    def main(self):"
Python_Script[75]="        # Called before each time step in calculation"
Python_Script[76]="        self.step = self.step + 1"
Python_Script[77]="        print('Step: ' + str(self.step) + '. Thermal Transient State - Main')"
Python_Script[78]=""
Python_Script[79]="    def final(self):"
Python_Script[80]="        # Called after calculation"
Python_Script[81]="        print('Thermal Transient - Final')"
Python_Script[82]=""
Python_Script[83]="    # This class contains functions for E-Magnetic calculations"
Python_Script[84]=""
Python_Script[85]=""
Python_Script[86]="class emagnetic():"
Python_Script[87]="    def initial(self):"
Python_Script[88]="        # Called before calculation"
Python_Script[89]="        print('E-Magnetic - Initial')"
Python_Script[90]=""
Python_Script[91]="    def final(self):"
Python_Script[92]="        # Called after calculation"
Python_Script[93]="        print('E-Magnetic - Final')"
Python_Script[94]=""
Python_Script[95]=""
Python_Script[96]="# This class contains functions for Mechanical Stress calculations"
Python_Script[97]="class mechanical_stress():"
